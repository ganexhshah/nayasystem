APP_NAME=NayaSystem
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://94.136.190.61
# IMPORTANT: In production, change to https:// and set FORCE_HTTPS=true
FORCE_HTTPS=false
SESSION_SECURE_COOKIES=false
# HSTS: Set true in production to enforce HTTPS (max-age in seconds)
ENABLE_HSTS=false
HSTS_MAX_AGE=31536000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=nayasystem
DB_USERNAME=naya_user
DB_PASSWORD=naya_password

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=auth.naymenu@gmail.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="auth.naymenu@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"
PASSWORD_RESET_EXPIRES=60

# Cloudflare R2 / AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
AWS_URL=https://pub-<hash>.r2.dev
AWS_USE_PATH_STYLE_ENDPOINT=true

# Sanctum & CORS Security
SANCTUM_STATEFUL_DOMAINS=94.136.190.61,localhost:3000,localhost:3001
CORS_ALLOWED_ORIGINS=http://94.136.190.61,http://localhost:3000,http://localhost:3001

# Firebase Configuration (do not commit)
FIREBASE_PROJECT=app
FIREBASE_CREDENTIALS=
GOOGLE_APPLICATION_CREDENTIALS=

# Frontend URL (for CORS)
FRONTEND_URL=http://94.136.190.61

# Firebase Admin SDK service account
# Store this file outside the repository and point to it with an absolute path.
# Example local path:
# FIREBASE_CREDENTIALS=C:/secure/firebase-service-account.json
# Example container path:
# FIREBASE_CREDENTIALS=/run/secrets/firebase-service-account.json

# Browsershot / Chromium
BROWSERSHOT_CHROMIUM_PATH=/usr/bin/chromium
